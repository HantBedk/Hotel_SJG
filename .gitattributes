# Default: normalize to LF on checkout for all text files
* text=auto eol=lf

# Shell scripts MUST be LF (run on Linux inside Docker)
*.sh text eol=lf

# PHP / JS / TS / JSON / YAML / CSS — all LF
*.php text eol=lf
*.ts  text eol=lf
*.tsx text eol=lf
*.js  text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.sql  text eol=lf
*.conf text eol=lf
*.ini  text eol=lf

# Windows scripts — keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary — no transformations
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.pdf  binary
*.zip  binary
