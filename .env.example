APP_NAME="Hotel Manager"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_LOCALE=es
APP_FALLBACK_LOCALE=es

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=hotel_sjg
DB_USERNAME=hotel_user
DB_PASSWORD=changeme_strong_password

BROADCAST_CONNECTION=reverb
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=480

REVERB_APP_ID=hotel_sjg
REVERB_APP_KEY=hotel_reverb_key
REVERB_APP_SECRET=changeme_reverb_secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

SANCTUM_STATEFUL_DOMAINS=
SANCTUM_TOKEN_EXPIRATION=480

# ── Puertos Docker ───────────────────────────────────────────────────────────
# Local con Laragon/IIS (recomendado — evita conflicto en puerto 80):
#   scripts\docker-local.cmd
#   HTTP_PORT=8080
#   APP_URL=http://localhost:8080
#   REVERB_HOST_PORT=8081
#
# Stack todo-en-uno en puerto 80 (sin Laragon):
#   HTTP_BIND=0.0.0.0   HTTP_PORT=80
#   REVERB_BIND=0.0.0.0 REVERB_HOST_PORT=8080
#
# VPS hotel.dataguaviare.com.co:
#   cp config/env.vps.example .env
#   bash scripts/deploy.sh
#   HTTP_BIND=127.0.0.1
#   HTTP_PORT=8081
#   APP_URL=https://hotel.dataguaviare.com.co
#   SANCTUM_STATEFUL_DOMAINS=hotel.dataguaviare.com.co
#   FRONTEND_ORIGINS=https://hotel.dataguaviare.com.co
#   SESSION_SECURE_COOKIE=true
#   VITE_REVERB_PORT=0
#   VITE_REVERB_SCHEME=https
#   nginx del host: docker/vps-hotel.dataguaviare.com.co.conf
# Reverb no necesita puerto público en VPS (WebSocket por /app vía nginx).

HTTP_BIND=127.0.0.1
HTTP_PORT=8080
REVERB_BIND=127.0.0.1
REVERB_HOST_PORT=8081
APP_URL=http://localhost:8080

FRONTEND_ORIGINS=

# Build del frontend (horneado en la imagen Docker)
VITE_REVERB_HOST=
VITE_REVERB_PORT=0
VITE_REVERB_SCHEME=
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"

# ── Backups ──────────────────────────────────────────────────────────────────
# Carpeta del PC donde se guardan los .zip de los backups automáticos.
# Ejemplos:
#   Windows:  BACKUP_HOST_PATH=D:\Hotel\backups
#   Linux:    BACKUP_HOST_PATH=/mnt/backups/hotel
#   Mac:      BACKUP_HOST_PATH=/Users/me/Hotel/backups
# Si lo dejas comentado o vacío, se usará ./backup dentro del proyecto.
# Requisitos:
#   - La carpeta debe existir antes de levantar el container.
#   - En Docker Desktop (Windows/Mac), la unidad debe estar autorizada en
#     Settings → Resources → File Sharing.
#
# Para migrar a otro PC:
#   1) Crear la carpeta nueva en el PC destino.
#   2) Cambiar BACKUP_HOST_PATH a la ruta nueva.
#   3) `docker compose up -d` para que tome el volumen actualizado.
#   4) Verificar desde la UI (Settings → Backups → Probar).
# La configuración en la DB no cambia — sigue apuntando a /var/www/html/backup
# (ruta dentro del container), y el volumen ahora resuelve al PC nuevo.
#BACKUP_HOST_PATH=
