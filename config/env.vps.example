# Hotel Manager — VPS hotel.dataguaviare.com.co
# Copiar en el servidor:  cp config/env.vps.example .env
# Completar APP_KEY, DB_PASSWORD y REVERB_APP_SECRET antes de deploy.

APP_NAME="Hotel Manager"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://hotel.dataguaviare.com.co

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=hotel_sjg
DB_USERNAME=hotel_user
DB_PASSWORD=CAMBIAR_PASSWORD_FUERTE

BROADCAST_CONNECTION=reverb
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=480

REVERB_APP_ID=hotel_sjg
REVERB_APP_KEY=hotel_reverb_key
REVERB_APP_SECRET=CAMBIAR_SECRETO_REVERB
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=https

SANCTUM_STATEFUL_DOMAINS=hotel.dataguaviare.com.co
SANCTUM_TOKEN_EXPIRATION=480
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

FRONTEND_ORIGINS=https://hotel.dataguaviare.com.co

# Puertos: nginx del host usa 80/443; el contenedor solo en localhost
HTTP_BIND=127.0.0.1
HTTP_PORT=8081

# Reverb sin puerto público (WebSocket por /app vía nginx)
REVERB_BIND=127.0.0.1
REVERB_HOST_PORT=8080

# Frontend horneado en la imagen — mismo origen HTTPS
VITE_REVERB_HOST=
VITE_REVERB_PORT=0
VITE_REVERB_SCHEME=https
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"

# Backups en disco del VPS
BACKUP_HOST_PATH=/var/backups/hotel
