# React build output (built inside Docker)
frontend/dist/

# TypeScript incremental build
*.tsbuildinfo

# Docker volumes
postgres_data/

# Logs de build locales
build.log

# Scripts de depuración local (no versionar)
scripts/debug/

# Planning docs (never committed)
Planes/

# Claude local config
.claude/

# Archivos de estructura vacía (directorios los crea Docker)
.gitkeep

# gitignore locales de subcarpetas (el root los cubre)
backend/.gitignore
frontend/.gitignore

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE — compartir solo configuración de equipo
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tailwind.css-data.json
*.swp
*.swo
